#!/bin/bash

SYSTEM=`uname`
if [ "$SYSTEM" = "Linux" ]; then
	FILE=`readlink -f $0`
elif [ "$SYSTEM" = "Darwin" ]; then
	FILE=`greadlink -f $0`
else
	echo "Error: unknown system"
	exit
fi
CURRENT=`pwd`
BIN=`dirname "$FILE"`
HOME=`dirname "$BIN"`
cd "$HOME"
{
	python3 scripts/login.py
} || {
	echo "Failed to login :-("
}
cd "$CURRENT"
